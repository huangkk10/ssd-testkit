<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>cdi</id>
    <version>8.17.13</version>
    <title>CrystalDiskInfo (8.17.13)</title>
    <authors>SSD TestKit</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>
      Offline portable installation of CrystalDiskInfo 8.17.13.
      Copies DiskInfo64.exe and all resources to C:\tools\CrystalDiskInfo
      and sets the CDI_PATH environment variable.
      Requires SSD_TESTKIT_ROOT environment variable to locate the source files.
    </description>
    <tags>cdi crystaldiskinfo diskinfo portable offline</tags>
  </metadata>
</package>
