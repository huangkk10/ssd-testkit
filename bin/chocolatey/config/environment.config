# environment.config — 環境旗標
# ================================
# 由 CI/CD、部署人員或 bootstrap.ps1 在執行前設定。
# 切換部署環境時只需修改此檔案，packages.config 與腳本不需動。

# 目前使用的套件來源（offline | nexus | nas）
active_source: offline

# Chocolatey 本體版本（對應 bin/chocolatey/installer/chocolatey.<version>.nupkg）
choco_version: "2.7.0"

# 安裝前驗證 sha256 雜湊（建議保持 true）
verify_hash: true

# 是否允許降級安裝舊版本
allow_downgrade: false

# Proxy 設定（有 proxy 的環境填入，無則留空）
# bootstrap.ps1 目前透過 PowerShell WebClient 設定，此欄位供文件記錄用
proxy_url: "http://10.10.10.190:3128"
