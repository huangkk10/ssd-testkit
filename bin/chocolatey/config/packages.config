<?xml version="1.0" encoding="utf-8"?>
<!--
  packages.config — 離線套件宣告清單
  ====================================
  每次部署前確認此清單，確保版本與目標環境一致。

  欄位說明：
    id      : Chocolatey 套件 ID（對應 bin/chocolatey/packages/<id>/ 目錄名）
    version : 要安裝的版本號（對應版本子目錄名）

  WindowsADK 版本對照：
    19041 = Windows 10 2004
    22000 = Windows 11 21H2
    22621 = Windows 11 22H2/23H2  ← 目前預設
    26100 = Windows 11 24H2
-->
<packages>
  <!-- 核心測試工具 -->
  <!-- <package id="burnin"      version="9.3.1000" /> -->
  <!-- <package id="cdi"         version="8.1.0"    /> -->
  <!-- <package id="pwrtest"     version="1.9.0"    /> -->
  <!-- <package id="dotnet"      version="8.0.0"    /> -->

  <!-- Windows ADK（以 Build Number 為版本識別） -->
  <package id="windows-adk" version="22621.0.0" />   <!-- Win11 22H2/23H2 -->

  <!-- Playwright browser binaries -->
  <package id="playwright-browsers" version="1.58.0" />

  <!-- .NET SDK -->
  <package id="net-7-sdk" version="7.0.410" />

  <!-- CrystalDiskInfo -->
  <package id="cdi" version="8.17.13" />

  <!-- SMI Windows Tools -->
  <package id="smiwintools" version="2026.2.13" />

  <!-- Powerhouse Mountain (PHM) — NDA software -->
  <package id="phm" version="4.22.0" />
</packages>
