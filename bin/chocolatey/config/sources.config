# sources.config — 套件來源設定
# =================================
# 支援三種模式：offline / nexus / nas
# 切換模式只需修改 environment.config 的 active_source，本檔案不需動。

default_source: offline

sources:

  # ── 離線模式（預設）────────────────────────────────────────────────────────
  # nupkg 放在本地 bin/chocolatey/packages/ 目錄
  offline:
    type: local_folder
    path: "bin/chocolatey/packages"    # 相對於專案根目錄（由 bootstrap.ps1 轉為絕對路徑）
    description: "本地離線套件資料夾"

  # ── Nexus NuGet Hosted Repository（未來）──────────────────────────────────
  # 建立方式：Nexus → Repositories → Create → nuget (hosted)，名稱 choco-hosted
  nexus:
    type: nuget_v3
    url: "https://nexus.internal/repository/choco-hosted/"
    api_key_env: "NEXUS_API_KEY"       # 從環境變數讀取，不寫死憑證
    description: "Nexus NuGet hosted repository"

  # ── NAS 共用資料夾（未來）─────────────────────────────────────────────────
  # 將 bin/chocolatey/packages/ 複製至 NAS，多台測試機共用
  nas:
    type: local_folder
    path: "\\\\NAS_HOST\\ssd-testkit\\chocolatey\\packages"   # UNC 路徑，依實際修改
    description: "NAS 共用資料夾"
